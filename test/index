                            <input type="email" id="lpb-email" placeholder="you@example.com" autocomplete="email">
                        </div>
                    </div>

                    <!-- Submit -->
                    <div class="lpb-submit-wrap">
                        <button class="lpb-submit" id="lpb-submit-btn" disabled="">Book Appointment</button>
