    <!-- Paystack Inline API -->
    <script src="https://js.paystack.co/v1/inline.js"></script>

    <style>
        /* Color Variables for Light & Dark Mode — same brand accent
           throughout (this is the established Libertypictures gold used
           across the whole business), neutrals warmed and deepened for
           a richer, more editorial feel than the flat greys before. */
        :root {
            --bg-body: #faf8f4;
            --bg-container: #ffffff;
            --bg-card: #fefdfb;
            --bg-booking: #f7f4ee;
            --text-primary: #1a1815;
            --text-secondary: #6b6459;
            --accent: #8a7355;
            --accent-deep: #6e5c44;
            --border-color: #e8e3d9;
            --border-dashed: #d8d1c2;
            --btn-primary-bg: #1a1815;
            --btn-primary-text: #ffffff;
            --highlight-bg: #f8f4ec;
            --shadow-subtle: rgba(26,24,21,0.04);
            --shadow-hover: rgba(26,24,21,0.10);
            --shadow-lift: rgba(26,24,21,0.16);
            --logo-filter: invert(0);
            --hero-scrim-rgb: 20,18,16;
            --radius-lg: 18px;
            --radius-md: 12px;
            --radius-sm: 6px;
        }

        /* Dark Mode Override — a genuinely different warm-charcoal
           palette, not a flat inversion. */
        @media (prefers-color-scheme: dark) {
            :root {
                --bg-body: #161513;
                --bg-container: #1f1e1b;
                --bg-card: #262521;
                --bg-booking: #1c1b18;
                --text-primary: #f3f0ea;
                --text-secondary: #a8a196;
                --accent: #c4a67e;
                --accent-deep: #d9bf98;
                --border-color: #35332d;
                --border-dashed: #423f37;
                --btn-primary-bg: #c4a67e;
                --btn-primary-text: #161513;
                --highlight-bg: #24221d;
                --shadow-subtle: rgba(0,0,0,0.24);
                --shadow-hover: rgba(0,0,0,0.42);
                --shadow-lift: rgba(0,0,0,0.55);
                --logo-filter: invert(1);
                --hero-scrim-rgb: 6,6,7;
            }
        }

        /* Modern Editorial Reset */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        a:focus-visible, button:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible, [tabindex]:focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 2px;
        }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg-body); 
            color: var(--text-primary); 
            line-height: 1.65;
            -webkit-font-smoothing: antialiased;
            padding: 80px 20px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        .serif { font-family: 'Fraunces', serif; }

        .container {
            max-width: 900px; 
            margin: 0 auto;
            background-color: var(--bg-container);
            padding: 96px 80px;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 32px var(--shadow-subtle); 
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        /* Header Layout — the brand mark now sits within a quieter,
           more spacious editorial block; the eyebrow label is softened
           and the intro copy is set in a size that reads as a genuine
           welcome rather than dense instructions. */
        .brand-header { margin-bottom: 64px; text-align: center; }
        .brand-logo { max-width: 82px; height: auto; margin: 0 auto 22px auto; display: block; filter: var(--logo-filter); transition: filter 0.3s ease; }
        .brand-subtitle { font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: var(--accent); font-weight: 600; margin-bottom: 22px; display: block; }
        .brand-intro { font-size: 15.5px; max-width: 480px; line-height: 1.85; margin: 0 auto; color: var(--text-secondary); }
        .brand-intro span { color: var(--accent); font-weight: 500; }
        
        /* Section Architecture — considerably more air between major
           blocks, per the brief's explicit call for breathing room. */
        .section-block { margin-bottom: 100px; }
        
        #addons { scroll-margin-top: 40px; }
        #secure-session { scroll-margin-top: 100px; }
        
        .section-title { font-family: 'Fraunces', serif; font-weight: 500; font-size: 30px; letter-spacing: -0.3px; color: var(--text-primary); margin-bottom: 14px; text-align: center; border: none; padding: 0; }
        .section-meta { font-size: 14px; color: var(--text-secondary); font-style: normal; margin-top: 0; margin-bottom: 44px; text-align: center; max-width: 440px; margin-left: auto; margin-right: auto; line-height: 1.7; }

        /* ---------- CLIENT JOURNEY — a small, honest editorial addition:
           the exact same three real steps the stepper already tracks,
           introduced once at the top as a calm establishing moment
           rather than software chrome. Purely presentational; touches
           no logic, no IDs the scripts depend on. ---------- */
        .lp-journey { display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 56px; flex-wrap: wrap; }
        .lp-journey-step { display: flex; flex-direction: column; align-items: center; gap: 10px; width: 130px; }
        .lp-journey-num { font-family: 'Fraunces', serif; font-style: italic; font-size: 20px; color: var(--accent); }
        .lp-journey-label { font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-secondary); text-align: center; font-weight: 500; }
        .lp-journey-line { width: 46px; height: 1px; background: var(--border-dashed); margin: 0 4px 26px; flex-shrink: 0; }
        @media (max-width: 600px) {
            .lp-journey { display: none; }
        }

        /* PACKAGES — same focus-carousel mechanic as before (untouched
           in behavior), presented with softer, deeper shadows and a
           more generous radius for an editorial print-card feel. */
        .tier-stack { display: flex; flex-direction: column; align-items: center; gap: 52px; max-width: 460px; margin: 0 auto; }
        .tier-stack .tier-card {
            width: 100%;
            opacity: 0.55; transform: scale(0.86);
            transition: opacity 0.42s ease-in-out, transform 0.42s ease-in-out;
        }
        .tier-stack .tier-card.is-focused { opacity: 1; transform: scale(1); }
        .tier-stack .tier-card.is-focused.photo-revealed .tier-scrim { transition-delay: 0.55s; }

        .tier-card { position: relative; overflow: hidden; aspect-ratio: 3 / 4; min-height: 380px; background-color: var(--bg-card); border: none; border-radius: var(--radius-lg); transition: all 0.4s cubic-bezier(0.16,1,0.3,1); box-shadow: 0 8px 28px var(--shadow-subtle); }
        .tier-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: var(--radius-lg) var(--radius-lg) 0 0; background: linear-gradient(90deg, transparent, var(--accent), transparent); opacity: 0; transition: opacity 0.35s ease; z-index: 2; }
        .tier-card:hover { transform: translateY(-6px); box-shadow: 0 22px 44px var(--shadow-lift); }
        .tier-card:hover::before { opacity: 1; }
        .tier-card.selected { box-shadow: 0 22px 44px var(--shadow-lift); }
        .tier-card.selected::before { opacity: 1; }

        .tier-photo-full { position: absolute; inset: 0; z-index: 0; }
        .tier-photo-full img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .tier-card.no-photo .tier-photo-full { background: #1f1a14; }
        .tier-scrim {
            position: absolute; left: 0; right: 0; bottom: 0; z-index: 1;
            background: linear-gradient(to top, rgba(15,12,9,0.95) 0%, rgba(15,12,9,0.8) 60%, rgba(15,12,9,0) 100%);
            padding: 76px 26px 26px 26px;
            opacity: 0; transform: translateY(14px);
            transition: opacity 0.85s cubic-bezier(0.33, 0, 0.2, 1), transform 0.85s cubic-bezier(0.33, 0, 0.2, 1);
        }
        .tier-card.photo-revealed .tier-scrim { opacity: 1; transform: translateY(0); }
        .tier-scrim h3 { font-family: 'Fraunces', serif; font-weight: 500; font-size: 20px; letter-spacing: 0; text-transform: none; margin-bottom: 14px; color: #f6f1e7; }

        .tier-details { list-style: none; font-size: 13px; color: #d9cdb8; margin-bottom: 22px; line-height: 1.8; }
        .tier-details li { margin-bottom: 6px; position: relative; padding-left: 16px; }
        .tier-details li::before { content: "—"; font-size: 12px; position: absolute; left: 0; top: 1px; color: var(--accent); font-weight: 400; }

        .tier-price-box { display: flex; align-items: center; justify-content: space-between; border-top: 1px solid rgba(246,241,231,0.18); padding-top: 16px; }
        .tier-price { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 500; color: #f6f1e7; letter-spacing: 0; }
        .select-btn {
            width: auto;
            min-width: 140px;
            background-color: rgba(246,241,231,0.08);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(246,241,231,0.5);
            color: #f6f1e7;
            padding: 11px 24px;
            font-size: 10.5px;
            text-transform: uppercase;
            letter-spacing: 1.8px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            border-radius: 30px;
        }
        .select-btn:hover { background-color: rgba(246,241,231,0.2); border-color: #f6f1e7; }
        .tier-card.selected .select-btn { background-color: var(--accent); border-color: var(--accent); color: #fff; }

        /* Generic premium ease-in/out scroll reveal — unchanged mechanics */
        .lp-reveal.reveal-pending { opacity: 0; transform: translateY(28px); }
        .lp-reveal.reveal-settled { opacity: 1; transform: translateY(0); }
        @keyframes lp-reveal-in-kf {
            from { opacity: 0; transform: translateY(28px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes lp-reveal-out-kf {
            from { opacity: 1; transform: translateY(0); }
            to { opacity: 0; transform: translateY(28px); }
        }
        .lp-reveal.reveal-in { animation: lp-reveal-in-kf 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .lp-reveal.reveal-out { animation: lp-reveal-out-kf 0.5s cubic-bezier(0.7, 0, 0.84, 0) forwards; }

        /* Add-ons Box — border removed in favor of a soft shadow + tint,
           reading as one calm surface rather than a bordered form panel. */
        .addons-container { max-width: 600px; margin: 0 auto; border: 1px solid var(--border-color); padding: 36px 34px; background-color: var(--bg-card); border-radius: var(--radius-md); opacity: 0.45; pointer-events: none; transition: 0.35s ease; box-shadow: 0 4px 20px var(--shadow-subtle); }
        .addons-container.active { opacity: 1; pointer-events: auto; border-color: var(--accent); }
        .addon-row { display: flex; justify-content: space-between; align-items: center; font-size: 14px; padding: 15px 0; border-bottom: 1px dashed var(--border-dashed); cursor: pointer; transition: 0.2s;}
        .addon-row:first-child { padding-top: 0; }
        .addon-row:last-child { padding-bottom: 0; border-bottom: none; }
        
        .addon-label { display: flex; align-items: center; gap: 14px; cursor: pointer; width: 100%; font-weight: 400; }
        .addon-label input { accent-color: var(--accent); width: 18px; height: 18px; cursor: pointer; }
        .addon-price { font-weight: 500; color: var(--accent); white-space: nowrap; font-family: 'Fraunces', serif; }

        /* Invoice Summary Box */
        .invoice-box { max-width: 600px; margin: 28px auto 0 auto; background-color: var(--highlight-bg); border: 1px solid var(--border-color); padding: 34px; border-radius: var(--radius-md); display: none; }
        .invoice-box.active { display: block; animation: fadeIn 0.5s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .invoice-row { display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 13px; color: var(--text-secondary); }
        .invoice-total { border-top: 1px solid var(--border-color); margin-top: 16px; padding-top: 16px; font-weight: 600; color: var(--text-primary); font-size: 16px; display: flex; justify-content: space-between; }
        .invoice-retainer { background-color: var(--accent); color: #fff; padding: 17px 18px; margin-top: 22px; display: flex; justify-content: space-between; align-items: center; font-weight: 500; font-size: 16px; border-radius: var(--radius-sm); }

        /* Booking Section */
        .booking-section { margin-top: 100px; background-color: var(--bg-booking); padding: 72px 44px; border-radius: var(--radius-lg); border: none; box-shadow: 0 4px 24px var(--shadow-subtle); }
        .step-heading { font-family: 'Fraunces', serif; font-weight: 500; font-size: 24px; text-transform: none; letter-spacing: 0; margin-bottom: 28px; text-align: center; border: none; padding-bottom: 0; }

        /* Payment Wrapper */
        .payment-wrapper { max-width: 600px; margin: 0 auto; text-align: center; padding: 52px 38px; background-color: var(--bg-container); border: 1px solid var(--border-color); border-radius: var(--radius-lg); box-shadow: 0 16px 40px var(--shadow-subtle); }
        .payment-recap-box {
            text-align: left;
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            padding: 18px 22px;
            margin-bottom: 30px;
            background-color: var(--highlight-bg);
        }
        .payment-recap-row {
            display: flex; justify-content: space-between; align-items: baseline;
            font-size: 13.5px; color: var(--text-secondary); gap: 16px;
        }
        .payment-recap-row + .payment-recap-row {
            margin-top: 11px; padding-top: 11px; border-top: 1px dashed var(--border-dashed);
        }
        .payment-recap-retainer-row { font-weight: 600; color: var(--accent); font-size: 14.5px; }
        
        .input-group { margin-bottom: 22px; text-align: left; }
        .input-label { display: block; font-size: 11.5px; text-transform: uppercase; letter-spacing: 1.2px; margin-bottom: 9px; color: var(--text-secondary); font-weight: 500; }
        .email-input { width: 100%; padding: 15px 16px; background: var(--bg-body); border: 1.5px solid var(--border-color); color: var(--text-primary); font-family: 'Poppins'; border-radius: var(--radius-sm); font-size: 16px; outline: none; transition: border-color 0.25s ease, box-shadow 0.25s ease; }
        .email-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3.5px rgba(138,115,85,0.12); }

        .cta-btn-primary { display: block; width: 100%; background-color: var(--btn-primary-bg); color: var(--btn-primary-text); padding: 19px 45px; font-size: 13.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 1.8px; border: none; border-radius: 30px; cursor: pointer; transition: all 0.4s cubic-bezier(0.16,1,0.3,1); }
        .cta-btn-primary:hover { background-color: var(--accent); color: #fff; transform: translateY(-2px); box-shadow: 0 16px 32px rgba(138, 115, 85, 0.28); }
        .cta-btn-primary:disabled { background-color: var(--border-color); color: var(--text-secondary); cursor: not-allowed; transform: none; box-shadow: none; }
        
        /* Policies — quieter, editorial presentation; no card chrome,
           just calm columns of text with generous line length control. */
        .protocol-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px 40px; }
        .protocol-item h3 { font-family: 'Fraunces', serif; font-weight: 500; font-size: 16px; text-transform: none; letter-spacing: 0; margin-bottom: 12px; }
        .protocol-item p { font-size: 13.5px; color: var(--text-secondary); text-align: left; line-height: 1.85; }
        .highlight-text { color: var(--accent); font-weight: 600; }

        .brand-footer { margin-top: 60px; padding-top: 44px; border-top: 1px solid var(--border-color); text-align: center; }

        /* Progress Stepper — same tracking mechanic, refined into a
           quieter, more considered visual language: thinner lines, more
           restrained typography, softer transitions. */
        .stepper-sentinel { height: 1px; }
        .sticky-progress-wrap {
            position: sticky;
            top: 0;
            z-index: 500;
            background-color: var(--bg-container);
            margin: 0 -80px 40px -80px;
            padding: 28px 80px 20px 80px;
            transition: padding 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
            border-bottom: 1px solid transparent;
        }
        .sticky-progress-wrap.is-stuck {
            padding-top: 12px;
            padding-bottom: 10px;
            box-shadow: 0 12px 28px var(--shadow-hover);
            border-bottom-color: var(--border-color);
        }
        .progress-stepper { display: flex; align-items: center; justify-content: center; max-width: 460px; margin: 0 auto; transition: max-width 0.35s ease; }
        .sticky-progress-wrap.is-stuck .progress-stepper { max-width: 280px; }
        .stepper-item { display: flex; flex-direction: column; align-items: center; gap: 9px; flex: 0 0 auto; }
        .stepper-circle { width: 30px; height: 30px; border-radius: 50%; border: 1px solid var(--border-color); display: flex; align-items: center; justify-content: center; font-family: 'Fraunces', serif; font-size: 13px; font-weight: 500; color: var(--text-secondary); background-color: var(--bg-container); transition: all 0.35s cubic-bezier(0.16,1,0.3,1); }
        .sticky-progress-wrap.is-stuck .stepper-circle { width: 18px; height: 18px; font-size: 8px; }
        .stepper-label { font-size: 9.5px; text-transform: uppercase; letter-spacing: 1.2px; color: var(--text-secondary); white-space: nowrap; transition: all 0.3s ease; font-weight: 500; }
        .sticky-progress-wrap.is-stuck .stepper-label { font-size: 6px; }
        .stepper-item.active .stepper-circle { border-color: var(--accent); background-color: var(--accent); color: #fff; }
        .stepper-item.active .stepper-label { color: var(--text-primary); font-weight: 600; }
        .stepper-item.done .stepper-circle { border-color: var(--accent); background-color: var(--bg-container); color: var(--accent); }
        .stepper-item.done .stepper-label { color: var(--accent); }
        .stepper-line { flex: 1 1 auto; height: 1px; background-color: var(--border-color); margin: 0 10px; margin-bottom: 19px; transition: background-color 0.3s ease, margin-bottom 0.3s ease; }
        .sticky-progress-wrap.is-stuck .stepper-line { margin-bottom: 11px; }
        .stepper-line.done { background-color: var(--accent); }

        /* ============================================================
           LP BOOKING COMPONENT CSS — same namespace, refined tokens
           ============================================================ */
        [data-lp-booking] {
            --lpb-bg:          #ffffff;
            --lpb-surface:     #faf8f4;
            --lpb-surface2:    #f2ede2;
            --lpb-border:      #e8e3d9;
            --lpb-text:        #1a1815;
            --lpb-muted:       #6b6459;
            --lpb-accent:      #8a7355;
            --lpb-accent-soft: rgba(138,115,85,.12);
            --lpb-accent-text: #ffffff;
            --lpb-disabled:    #c9c6bf;
            --lpb-input-bg:    #faf8f4;
            --lpb-shadow:      0 4px 24px rgba(26,24,21,.06);
            --lpb-radius:      18px;
            --lpb-radius-sm:   9px;
            --lpb-transition:  0.25s cubic-bezier(0.16,1,0.3,1);
        }
        @media (prefers-color-scheme: dark) {
            [data-lp-booking] {
                --lpb-bg:          #1c1b18;
                --lpb-surface:     #232220;
                --lpb-surface2:    #2c2a26;
                --lpb-border:      #383530;
                --lpb-text:        #f3f0ea;
                --lpb-muted:       #a8a196;
                --lpb-accent:      #c4a67e;
                --lpb-accent-soft: rgba(196,166,126,.16);
                --lpb-accent-text: #1c1b18;
                --lpb-disabled:    #47443c;
                --lpb-input-bg:    #232220;
                --lpb-shadow:      0 4px 24px rgba(0,0,0,.4);
            }
        }
        [data-lp-booking] {
            background: var(--lpb-bg);
            color: var(--lpb-text);
            font-family: 'Poppins', sans-serif;
            padding: 88px 20px;
            transition: background var(--lpb-transition), color var(--lpb-transition);
        }
        .lpb-inner { max-width: 620px; margin: 0 auto; }
        .lpb-heading { text-align: center; margin-bottom: 34px; }
        .lpb-heading h2 {
            font-family: 'Fraunces', serif; font-weight: 500; font-size: 26px; letter-spacing: 0; text-transform: none;
            color: var(--lpb-text); margin-bottom: 12px;
        }
        .lpb-heading p { font-size: 13.5px; color: var(--lpb-muted); margin-top: 6px; line-height: 1.7; }
        .lpb-card {
            background: var(--lpb-surface);
            border: 1px solid var(--lpb-border);
            border-radius: var(--lpb-radius);
            padding: 42px 36px;
            box-shadow: var(--lpb-shadow);
            transition: background var(--lpb-transition), border-color var(--lpb-transition);
        }
        .lpb-step-label {
            font-size: 10.5px; letter-spacing: 2.5px; text-transform: uppercase;
            font-weight: 600; color: var(--lpb-accent); margin-bottom: 20px; display: block;
        }
        .lpb-cal-nav {
            display: flex; align-items: center;
            justify-content: space-between; margin-bottom: 22px;
        }
        .lpb-cal-nav-btn {
            background: none; border: 1px solid var(--lpb-border); border-radius: 50%;
            width: 34px; height: 34px; display: flex; align-items: center;
            justify-content: center; cursor: pointer; color: var(--lpb-text);
            transition: background var(--lpb-transition), border-color var(--lpb-transition);
            flex-shrink: 0;
        }
        .lpb-cal-nav-btn:hover:not(:disabled) { background: var(--lpb-surface2); border-color: var(--lpb-accent); }
        .lpb-cal-nav-btn:disabled { opacity: 0.3; cursor: not-allowed; }
        .lpb-cal-nav-btn svg { pointer-events: none; }
        .lpb-cal-month { font-family: 'Fraunces', serif; font-size: 16px; font-weight: 500; letter-spacing: 0; color: var(--lpb-text); }
        .lpb-cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
        .lpb-cal-dow {
            font-size: 10px; letter-spacing: 1px; text-transform: uppercase;
            color: var(--lpb-muted); text-align: center; padding: 6px 0 12px; font-weight: 500;
        }
        .lpb-cal-day {
            aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
            border-radius: 50%; font-size: 13px; cursor: pointer;
            transition: all var(--lpb-transition); border: none; background: none;
            color: var(--lpb-text); font-family: 'Poppins', sans-serif;
            -webkit-tap-highlight-color: transparent; position: relative;
        }
        .lpb-cal-day:not(.lpb-day-disabled):not(.lpb-day-empty):hover {
            background: var(--lpb-accent-soft); color: var(--lpb-accent);
        }
        .lpb-cal-day.lpb-day-today { font-weight: 700; color: var(--lpb-accent); }
        .lpb-cal-day.lpb-day-today::after {
            content: ''; position: absolute; bottom: 4px; left: 50%;
            transform: translateX(-50%); width: 4px; height: 4px;
            border-radius: 50%; background: var(--lpb-accent);
        }
        .lpb-cal-day.lpb-day-selected {
            background: var(--lpb-accent) !important;
            color: var(--lpb-accent-text) !important;
            font-weight: 600; box-shadow: 0 4px 14px rgba(138,115,85,.35);
        }
        .lpb-cal-day.lpb-day-selected::after { display: none; }
        .lpb-cal-day.lpb-day-disabled { color: var(--lpb-disabled); cursor: not-allowed; pointer-events: none; }
        .lpb-cal-day.lpb-day-empty { pointer-events: none; }
        .lpb-divider { height: 1px; background: var(--lpb-border); margin: 32px 0; transition: background var(--lpb-transition); }
        .lpb-times { display: grid; grid-template-columns: repeat(auto-fill, minmax(108px, 1fr)); gap: 10px; }
        .lpb-time-btn {
            padding: 13px 10px; border: 1px solid var(--lpb-border);
            border-radius: var(--lpb-radius-sm); background: var(--lpb-surface);
            color: var(--lpb-text); font-family: 'Poppins', sans-serif;
            font-size: 13px; font-weight: 500; cursor: pointer; text-align: center;
            transition: all var(--lpb-transition); -webkit-tap-highlight-color: transparent;
        }
        .lpb-time-btn:hover { border-color: var(--lpb-accent); background: var(--lpb-accent-soft); color: var(--lpb-accent); }
        .lpb-time-btn.lpb-time-selected {
            background: var(--lpb-accent); border-color: var(--lpb-accent);
            color: var(--lpb-accent-text); box-shadow: 0 4px 14px rgba(138,115,85,.30);
        }
        .lpb-times-placeholder {
            font-size: 13.5px; color: var(--lpb-muted); font-style: italic;
            text-align: center; padding: 14px 0; margin: 0;
        }
        .lpb-fields { display: flex; flex-direction: column; gap: 18px; }
        .lpb-field { display: flex; flex-direction: column; gap: 8px; }
        .lpb-field label {
            font-size: 11px; text-transform: uppercase; letter-spacing: 1px;
            font-weight: 600; color: var(--lpb-muted);
        }
        .lpb-field input, .lpb-field textarea {
            width: 100%; padding: 15px 17px; background: var(--lpb-input-bg);
            border: 1.5px solid var(--lpb-border); border-radius: var(--lpb-radius-sm);
            color: var(--lpb-text); font-family: 'Poppins', sans-serif; font-size: 16px;
            outline: none; transition: border-color var(--lpb-transition), box-shadow var(--lpb-transition);
            -webkit-appearance: none; box-sizing: border-box;
        }
        .lpb-field input::placeholder, .lpb-field textarea::placeholder { color: var(--lpb-disabled); }
        .lpb-field input:focus, .lpb-field textarea:focus {
            border-color: var(--lpb-accent); box-shadow: 0 0 0 3.5px var(--lpb-accent-soft);
        }
        .lpb-field textarea { resize: vertical; min-height: 90px; line-height: 1.6; }
        .lpb-submit-wrap { margin-top: 32px; }
        .lpb-submit {
            width: 100%; padding: 19px; background: var(--lpb-accent); border: none;
            border-radius: 50px; color: var(--lpb-accent-text); font-family: 'Poppins', sans-serif;
            font-size: 13px; font-weight: 600; letter-spacing: 1.6px; text-transform: uppercase;
            cursor: pointer; transition: all 0.35s cubic-bezier(0.16,1,0.3,1);
        }
        .lpb-submit:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 14px 32px rgba(138,115,85,.35); }
        .lpb-submit:active:not(:disabled) { transform: translateY(0); }
        .lpb-submit:disabled {
            background: var(--lpb-surface2); color: var(--lpb-disabled);
            cursor: not-allowed; box-shadow: none; transform: none;
        }
        .lpb-submit-hint { text-align: center; font-size: 11.5px; color: var(--lpb-muted); margin-top: 14px; min-height: 16px; }
        /* Confirmation banner — refined for a calmer, more premium
           moment, cinematic checkmark included. */
        .lpb-toast {
            display: none;
            align-items: flex-start;
            gap: 16px;
            margin-top: 28px;
            padding: 22px 24px;
            background: var(--lpb-accent-soft);
            border: 1px solid var(--lpb-accent);
            border-radius: var(--lpb-radius-sm);
        }
        .lpb-toast.lpb-visible { display: flex; animation: lpb-fade-up 0.5s cubic-bezier(0.16,1,0.3,1) forwards; }
        .lpb-toast-icon {
            width: 32px; height: 32px; border-radius: 50%; background: var(--lpb-accent);
            display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;
            animation: lpb-check-pop 0.5s cubic-bezier(0.34,1.56,0.64,1) 0.15s both;
        }
        @keyframes lpb-check-pop { from { transform: scale(0.4); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .lpb-toast-icon svg { color: var(--lpb-accent-text); }
        .lpb-toast-body h3 { font-family: 'Fraunces', serif; font-weight: 500; font-size: 15px; margin-bottom: 5px; color: var(--lpb-text); }
        .lpb-toast-body p { font-size: 12.5px; color: var(--lpb-muted); line-height: 1.7; margin: 0; }
        @keyframes lpb-fade-up {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .lpb-animate-in { animation: lpb-fade-up 0.4s ease forwards; }

        @media (min-width: 1200px) {
            .container {
                max-width: 1140px;
                padding: 110px 110px;
            }
            .addons-container, .invoice-box, .payment-wrapper {
                max-width: 680px;
            }
        }

        /* VIDEO HERO — cinematic editorial treatment: taller, quieter
           scrim, refined type. Same video/scrim mechanics as before. */
        .lp-hero { position: relative; height: 68vh; min-height: 460px; display: flex; align-items: flex-end; overflow: hidden; background: #141210; }
        .lp-hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 35%; }
        .lp-hero-scrim { position: absolute; inset: 0; background: linear-gradient(to top, rgba(var(--hero-scrim-rgb),0.72), rgba(var(--hero-scrim-rgb),0.05) 60%); }
        .lp-hero-content { position: relative; padding: 0 6vw 84px; color: #fff; max-width: 640px; margin: 0 auto; text-align: center; }
        .lp-hero-eyebrow { font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-bottom: 18px; font-weight: 500; }
        .lp-hero-title { font-family: 'Fraunces', serif; font-style: italic; font-weight: 400; font-size: clamp(26px, 4.4vw, 46px); letter-spacing: 0; word-spacing: 0; line-height: 1.25; margin-bottom: 0; color: rgba(255,255,255,0.94); text-shadow: 0 4px 24px rgba(0,0,0,0.4); }
        @media (max-width: 600px) {
            .lp-hero { height: 74vh; min-height: 480px; }
            .lp-hero-content { padding-bottom: 64px; }
            .lp-hero-title { font-size: clamp(24px, 7.2vw, 32px); white-space: normal; }
            .tier-stack { max-width: 100%; gap: 34px; }
        }

        /* PROMO POPUP — click-triggered only, never shown automatically */
        .lp-promo-overlay { position: fixed; inset: 0; background: rgba(20,18,16,0.55); z-index: 55; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; backdrop-filter: blur(2px); }
        .lp-promo-overlay.is-open { opacity: 1; pointer-events: auto; }
        .lp-promo-modal {
            position: fixed; left: 50%; top: 50%; transform: translate(-50%, -50%) scale(0.96); z-index: 56;
            width: min(440px, 90vw); max-height: 70vh; background: var(--bg-container);
            opacity: 0; pointer-events: none; transition: opacity 0.3s ease, transform 0.3s ease;
            display: flex; flex-direction: column; border-radius: var(--radius-md); box-shadow: 0 24px 64px rgba(0,0,0,0.32);
        }
        .lp-promo-modal.is-open { opacity: 1; transform: translate(-50%, -50%) scale(1); pointer-events: auto; }
        .lp-promo-header { display: flex; align-items: center; justify-content: space-between; padding: 22px 26px; border-bottom: 1px solid var(--border-color); font-family: 'Fraunces', serif; font-weight: 500; font-size: 16px; }
        .lp-promo-body { overflow-y: auto; padding: 10px 26px 26px; }

        /* ============================================================
           END LP BOOKING COMPONENT CSS
           ============================================================ */

        /* 📱 MOBILE OPTIMIZATION ENGINE */
        @media (max-width: 768px) {
            body { padding: 0; background-color: var(--bg-container); }
            .container { padding: 4px 20px 44px 20px; border: none; box-shadow: none; }
            .brand-header { margin-bottom: 20px; }
            .brand-logo { max-width: 58px; margin: 0 auto 10px auto; }
            .brand-subtitle { margin-bottom: 10px; }
            .brand-intro { font-size: 13.5px; line-height: 1.7; }
            .brand-intro, .section-title, .section-meta { text-align: center; }
            .section-title { font-size: 24px; }
            .section-block { margin-bottom: 68px; }

            .tier-card { border-radius: var(--radius-lg); box-shadow: 0 10px 26px var(--shadow-subtle); }
            .tier-scrim { padding: 56px 22px 22px 22px; }
            .select-btn { width: auto; min-width: 140px; padding: 12px 22px; font-size: 11px; text-align: center; }

            .addons-container, .invoice-box, .payment-wrapper { max-width: 400px; margin-left: auto; margin-right: auto;}
            .addons-container { padding: 26px 20px; }
            .addon-row { flex-direction: column; align-items: flex-start; gap: 8px; padding: 18px 0; }
            .addon-price { padding-left: 32px; font-size: 13.5px; }

            .booking-section { padding: 48px 16px; border-left: none; border-right: none; border-radius: 0; margin-left: -20px; margin-right: -20px; box-shadow: none; }

            .sticky-progress-wrap { margin: 0 -20px 28px -20px; padding: 18px 20px 14px 20px; }
            .sticky-progress-wrap.is-stuck { padding: 10px 20px 8px 20px; }
            .progress-stepper { max-width: 300px; }
            .sticky-progress-wrap.is-stuck .progress-stepper { max-width: 200px; }
            .stepper-label { font-size: 7.5px; }
            .stepper-circle { width: 26px; height: 26px; font-size: 11px; }
            .sticky-progress-wrap.is-stuck .stepper-circle { width: 16px; height: 16px; font-size: 7px; }
            .sticky-progress-wrap.is-stuck .stepper-label { font-size: 5.5px; }

            .payment-wrapper { padding: 40px 24px; }
            .protocol-grid { grid-template-columns: 1fr; gap: 36px; }

            [data-lp-booking] { padding: 60px 18px; }
            .lpb-card { padding: 32px 22px; }
            .lpb-cal-day { font-size: 12px; }
            .lpb-times { grid-template-columns: repeat(3, 1fr); gap: 8px; }
            .lpb-time-btn { padding: 12px 6px; font-size: 12px; }
        }
    </style>
</head>
<body>

    <section class="lp-hero">
        <video class="lp-hero-video" id="lp-hero-video" autoplay muted loop playsinline poster="">
            <!-- Add your video: put the file in the same folder as this
                 page (e.g. "studio-reel.mp4") and uncomment the line
                 below with that filename. Until then this section just
                 shows as a plain dark band — nothing breaks either way. -->
            <!-- <source src="studio-reel.mp4" type="video/mp4"> -->
        </video>
        <div class="lp-hero-scrim"></div>
        <div class="lp-hero-content">
            <div class="lp-hero-eyebrow">Libertypictures Studio</div>
            <h1 class="lp-hero-title">Intimate visual stories</h1>
        </div>
    </section>

    <div class="container">
        <header class="brand-header">
            <img src="logo.png" alt="Libertypictures" class="brand-logo" id="brand-logo-img">
            <h2 class="brand-subtitle">Reservations</h2>
            <p class="brand-intro">
                Thank you for your interest in our <span>service</span>.
                Select your desired <span>session</span>, book a <span>date</span>, and secure your <span>retainer</span> below.
            </p>
        </header>

        <!-- PROGRESS STEPPER (floats to the top while scrolling) -->
        <div class="stepper-sentinel" id="stepper-sentinel"></div>
        <div class="sticky-progress-wrap is-stuck" id="sticky-progress-wrap">
            <div class="progress-stepper" id="progress-stepper">
                <div class="stepper-item active" id="step-1">
                    <span class="stepper-circle">1</span>
                    <span class="stepper-label">Choose Session</span>
                </div>
                <div class="stepper-line" id="line-1"></div>
                <div class="stepper-item" id="step-2">
                    <span class="stepper-circle">2</span>
                    <span class="stepper-label">Date</span>
                </div>
                <div class="stepper-line" id="line-2"></div>
                <div class="stepper-item" id="step-3">
                    <span class="stepper-circle">3</span>
                    <span class="stepper-label">Payment</span>
                </div>
            </div>
        </div>

        <!-- CLIENT JOURNEY — an honest, purely presentational echo of the
             same three real steps above; a calm establishing moment,
             not new functionality. -->
        <div class="lp-journey" aria-hidden="true">
            <div class="lp-journey-step">
                <span class="lp-journey-num">01</span>
                <span class="lp-journey-label">Choose Your Session</span>
            </div>
            <span class="lp-journey-line"></span>
            <div class="lp-journey-step">
                <span class="lp-journey-num">02</span>
                <span class="lp-journey-label">Pick a Date</span>
            </div>
            <span class="lp-journey-line"></span>
            <div class="lp-journey-step">
                <span class="lp-journey-num">03</span>
                <span class="lp-journey-label">Secure with Retainer</span>
            </div>
        </div>

        <!-- PACKAGES SECTION -->
        <section class="section-block" id="packages">
            <h2 class="section-title serif">Our Sessions</h2>
            <p class="section-meta">Perfect for portraits, pre-birthdays, maternity, corporate headshots, duo, and family sessions.</p>
            <div class="tier-stack" id="packages-grid">
                <p style="text-align:center; color:var(--text-secondary); font-size:13px;">Loading sessions&hellip;</p>
            </div>
        </section>


        <!-- ADD-ONS SECTION -->
        <section class="section-block" id="addons">
            <h2 class="section-title serif">Custom Additions</h2>
            <p class="section-meta">Entirely optional — studio sessions already include a backdrop. Add these only for off-studio shoots or faster delivery.</p>
            <div class="addons-container" id="addons-box">
                <label class="addon-row">
                    <div class="addon-label">
                        <input type="checkbox" class="addon-checkbox" value="50000" data-name="Off-Studio Shoot — No Backdrop">
                        <span>Shoot at an Off-Studio Location — No Backdrop</span>
                    </div>
                    <span class="addon-price">₦50,000</span>
                </label>
                <label class="addon-row">
                    <div class="addon-label">
                        <input type="checkbox" class="addon-checkbox" value="70000" data-name="Off-Studio Shoot — With Backdrop">
                        <span>Shoot at an Off-Studio Location — With Backdrop</span>
                    </div>
                    <span class="addon-price">₦70,000</span>
                </label>
                <label class="addon-row" style="margin-top: 6px; border-top: 1px dashed var(--accent); padding-top: 18px;">
                    <div class="addon-label">
                        <input type="checkbox" class="addon-checkbox" value="30000" data-name="Express 24Hr Delivery">
                        <span>Express 24-Hour Digital Turnaround</span>
                    </div>
                    <span class="addon-price">+₦30,000</span>
                </label>
            </div>

            <!-- LIVE INVOICE SUMMARY -->
            <div class="invoice-box" id="invoice-ui">
                <h3 class="serif" style="font-size: 17px; font-weight: 500; margin-bottom: 18px;">Booking Summary</h3>
                <div class="invoice-row">
                    <span id="inv-package-name">Package Name</span>
                    <span id="inv-package-price">₦0</span>
                </div>
                <div id="inv-addons-list"></div>
                <div class="invoice-total">
                    <span>Subtotal</span>
                    <span id="inv-subtotal">₦0</span>
                </div>
                <div class="invoice-row" style="margin-top: 12px; font-size: 12.5px;">
                    <span>30% Balance (Due on session day)</span>
                    <span id="inv-balance">₦0</span>
                </div>
                <div class="invoice-retainer">
                    <span>70% Retainer Due Today:</span>
                    <span id="inv-retainer">₦0</span>
                </div>
            </div>
        </section>

        <!-- ================================================================
             LP BOOKING COMPONENT — native custom booking calendar
             ================================================================ -->
        <section data-lp-booking="" id="lp-booking">
            <div class="lpb-inner">

                <div class="lpb-heading">
                    <h2 class="serif">Appointment Calendar</h2>
                    <p>Choose a date and time — we'll confirm your session within 24 hours.</p>
                </div>

                <!-- BOOKING FORM CARD -->
                <div class="lpb-card" id="lpb-form-card">

                    <!-- Step 1: Calendar -->
                    <span class="lpb-step-label">Choose a Date</span>
                    <div class="lpb-cal-nav">
                        <button class="lpb-cal-nav-btn" id="lpb-prev-month" aria-label="Previous month" disabled="">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 1 3 7 9 13"></polyline>
                            </svg>
                        </button>
                        <span class="lpb-cal-month" id="lpb-cal-month-label" aria-live="polite">July 2026</span>
                        <button class="lpb-cal-nav-btn" id="lpb-next-month" aria-label="Next month">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="5 1 11 7 5 13"></polyline>
                            </svg>
                        </button>
                    </div>
                    <div class="lpb-cal-grid" id="lpb-cal-grid" role="grid" aria-label="Date picker"></div>

                    <div class="lpb-divider"></div>

                    <!-- Step 2: Time slots -->
                    <span class="lpb-step-label">Available Times</span>
                    <p class="lpb-times-placeholder" id="lpb-times-placeholder">Select a date to see available times</p>
                    <div class="lpb-times" id="lpb-times-grid" style="display:none;" role="group" aria-label="Available time slots"></div>

