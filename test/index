                <div class="input-group">
                    <label class="input-label" for="client-email">Email Address for Receipt</label>
                    <input type="email" id="client-email" class="email-input" placeholder="hello@example.com" required="">
                    <p style="font-size: 11px; margin-top: 8px; color: var(--text-secondary);">Pre-filled from your booking — edit if you'd like the receipt sent elsewhere.</p>
                </div>
                <label style="display:flex; align-items:flex-start; gap:9px; text-align:left; font-size:12px; color:var(--text-secondary); margin-bottom:24px; cursor:pointer; line-height:1.6;">
                    <input type="checkbox" id="policy-ack" style="margin-top:3px; flex-shrink:0;">
