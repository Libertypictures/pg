        <footer class="brand-footer">
            <span class="serif" style="font-size: 15px; letter-spacing: 0.3px; font-weight: 500;">Libertypictures © 2026</span>
            <div style="margin-top:14px;">
                <a href="#" id="lp-promo-trigger" style="font-size:11px; letter-spacing:1px; text-transform:uppercase; color: var(--accent); text-decoration:underline; cursor:pointer;">Current Promos</a>
            </div>
        </footer>
    </div>

    <!-- PROMO POPUP -->
    <div class="lp-promo-overlay" id="lp-promo-overlay"></div>
    <div class="lp-promo-modal" id="lp-promo-modal">
        <div class="lp-promo-header">
            <span class="serif">Current Promos</span>
            <button id="lp-promo-close" aria-label="Close" style="background:none; border:none; font-size:24px; color:var(--text-secondary); cursor:pointer; line-height:1;">&times;</button>
        </div>
        <div class="lp-promo-body">
            <p style="font-size:13px; color:var(--text-secondary); text-align:center; padding:20px 0;">Nothing running right now — check back soon, or follow the studio's socials so you don't miss the next one.</p>
        </div>
    </div>

    <!-- JAVASCRIPT FOR CART & PAYSTACK INTEGRATION -->
    <script>
        // HERO VIDEO + LOGO — loaded from Settings, same pattern as
        // Packages. Previously these only worked with files manually
        // added to the GitHub repo — now they actually read what's
        // uploaded in the dashboard.
        (function () {
            var API_BASE = 'https://liberty-booking-api.visualsliberty.workers.dev';
            fetch(API_BASE + '/api/settings')
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    var s = data.settings || {};

                    if (s.logo_url) {
                        var logoImg = document.getElementById('brand-logo-img');
                        if (logoImg) logoImg.src = API_BASE + s.logo_url;
                    }

                    if (!s.hero_video_url) return; // nothing uploaded yet — plain dark band is the correct fallback
                    var oldVideo = document.getElementById('lp-hero-video');
                    var newVideo = oldVideo.cloneNode(false);
                    newVideo.muted = true; // explicit property, not just the cloned attribute — autoplay strictly requires this and attribute-cloning can be inconsistent
                    newVideo.innerHTML = '<source src="' + API_BASE + s.hero_video_url + '" type="video/mp4">';
                    oldVideo.parentNode.replaceChild(newVideo, oldVideo);
                    newVideo.play().catch(function (err) { console.error('Hero video could not autoplay:', err.message); });
                })
                .catch(function (err) { console.error('Could not load hero video/logo from Settings:', err); });
        })();

        // PACKAGES — loaded from the real backend, matching the same
        // pattern used throughout Melisakim: whatever's in the dashboard
        // is exactly what shoppers see, no GitHub-hosted files involved.
        (function () {
            var API_BASE = 'https://liberty-booking-api.visualsliberty.workers.dev';
            var grid = document.getElementById('packages-grid');

            function escapeHtmlLocal(str) {
                var div = document.createElement('div');
                div.textContent = String(str == null ? '' : str);
                return div.innerHTML;
            }

            function cardHtml(p) {
                var photoHtml = p.imageUrl
                    ? '<img src="' + API_BASE + p.imageUrl + '" alt="' + escapeHtmlLocal(p.name) + '" loading="lazy" decoding="async">'
                    : '';
                var bullets = (p.description || '').split('\n').filter(function (line) { return line.trim(); });
                var bulletsHtml = bullets.length
                    ? '<ul class="tier-details">' + bullets.map(function (b) { return '<li>' + escapeHtmlLocal(b) + '</li>'; }).join('') + '</ul>'
                    : '';
                var priceLabel = '\u20a6' + Math.round(p.price / 1000) + 'k';

                return '<div class="tier-card' + (photoHtml ? '' : ' no-photo') + '" data-price="' + p.price + '" data-name="' + escapeHtmlLocal(p.name) + '">' +
                    '<div class="tier-photo-full">' + photoHtml + '</div>' +
                    '<div class="tier-scrim">' +
                        '<h3>' + escapeHtmlLocal(p.name) + '</h3>' +
                        bulletsHtml +
                        '<div class="tier-price-box">' +
                            '<span class="tier-price">' + priceLabel + '</span>' +
                            '<button class="select-btn" onclick="selectPackage(this)">Select Session</button>' +
                        '</div>' +
                    '</div>' +
                '</div>';
            }

            // Watches which card is nearest the center of the actual
            // browser viewport as the visitor scrolls the PAGE — there's
            // no separate scroll area here, this rides entirely on the
            // page's own single scroll. Whichever card is most central
            // gets visual focus; others recede but stay fully visible
            // and fully clickable the whole time.
            function initFocusTracking() {
                var cards = grid.querySelectorAll('.tier-card');
                if (!cards.length || !('IntersectionObserver' in window)) {
                    cards.forEach(function (c) { c.classList.add('is-focused', 'photo-revealed'); });
                    return;
                }

                // IntersectionObserver always fires once immediately with
                // whatever's already true the moment observing starts —
                // if a card happens to already sit in the center band as
                // soon as the section loads, that counts as this first,
                // automatic firing, not a real scroll action. Suppressing
                // transitions for just that first batch means it appears
                // instantly, correctly, without an unwanted "growing into
                // focus" animation nobody actually triggered by scrolling.
                var isFirstBatch = true;
                cards.forEach(function (c) { c.style.transition = 'none'; });

                var focusObserver = new IntersectionObserver(function (entries) {
                    entries.forEach(function (entry) {
                        var card = entry.target;
                        if (entry.isIntersecting) {
                            card.classList.add('is-focused', 'photo-revealed');
                        } else {
                            card.classList.remove('is-focused', 'photo-revealed');
                        }
                    });
                    if (isFirstBatch) {
                        isFirstBatch = false;
                        requestAnimationFrame(function () {
                            requestAnimationFrame(function () {
                                cards.forEach(function (c) { c.style.transition = ''; }); // restore normal animated transitions for every real scroll change from here on
                            });
                        });
                    }
                }, { rootMargin: '-25% 0px -25% 0px', threshold: 0 }); // a band across the middle of the actual screen — whichever card crosses into it becomes focused

                cards.forEach(function (card) { focusObserver.observe(card); });
            }

            fetch(API_BASE + '/api/packages?activeOnly=true')
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    var packages = (data.packages || []).slice().sort(function (a, b) { return a.displayOrder - b.displayOrder; });
                    if (!packages.length) {
                        grid.innerHTML = '<p style="text-align:center; color:var(--text-secondary); font-size:13px;">Sessions are being updated \u2014 check back shortly.</p>';
                        return;
                    }
                    grid.innerHTML = packages.map(cardHtml).join('');
                    requestAnimationFrame(function () {
                        requestAnimationFrame(function () {
                            initFocusTracking();
                        });
                    });
                })
                .catch(function (err) {
                    grid.innerHTML = '<p style="text-align:center; color:var(--text-secondary); font-size:13px;">Couldn\'t load sessions right now \u2014 please refresh.</p>';
                    console.error('Packages load failed:', err);
                });
        })();

        // PROMO POPUP — opens only on click, closes on the × / overlay / Escape
        (function () {
            var overlay = document.getElementById('lp-promo-overlay');
            var modal = document.getElementById('lp-promo-modal');
            var trigger = document.getElementById('lp-promo-trigger');
            var closeBtn = document.getElementById('lp-promo-close');
            function open(e) { if (e) e.preventDefault(); overlay.classList.add('is-open'); modal.classList.add('is-open'); }
            function close() { overlay.classList.remove('is-open'); modal.classList.remove('is-open'); }
            trigger.addEventListener('click', open);
            closeBtn.addEventListener('click', close);
            overlay.addEventListener('click', close);
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
        })();

        // HERO VIDEO — mobile browsers commonly pause video when the app
        // is backgrounded and won't resume it automatically; this brings
        // it back on the next real tap/scroll, since that's the one thing
        // iOS specifically still allows (a lesson learned building the
        // Melisakim site's hero video).
        (function () {
            function resume() {
                var video = document.getElementById('lp-hero-video');
                if (video && video.paused) video.play().catch(function () {});
            }
            document.addEventListener('visibilitychange', function () { if (document.visibilityState === 'visible') resume(); });
            window.addEventListener('pageshow', resume);
            ['touchstart', 'click'].forEach(function (evt) { document.addEventListener(evt, resume, { passive: true }); });
        })();

        // Floating Progress Stepper: watch a zero-height sentinel placed just
        // above the stepper. Once it scrolls out of view, the stepper is
        // stuck to the top, so we add a class to condense it into a slim bar.
        (function () {
            const sentinel = document.getElementById('stepper-sentinel');
            const wrap = document.getElementById('sticky-progress-wrap');
            if (sentinel && wrap && 'IntersectionObserver' in window) {
                const observer = new IntersectionObserver(
                    ([entry]) => wrap.classList.toggle('is-stuck', !entry.isIntersecting),
                    { threshold: 0 }
                );
                observer.observe(sentinel);
            }
        })();

        // State Management
        let cart = {
            basePrice: 0,
            baseName: "",
            addons: [],
            subtotal: 0,
            retainer: 0,
            balance: 0
        };

        const formatNaira = (amount) => {
            return new Intl.NumberFormat('en-NG', { style: 'currency', currency: 'NGN', maximumFractionDigits: 0 }).format(amount);
        };

        // Progress Stepper Control
        function updateStep(stepNumber) {
            document.querySelectorAll('.stepper-item').forEach((el, idx) => {
                const n = idx + 1;
                el.classList.remove('active', 'done');
                if (n < stepNumber) el.classList.add('done');
                else if (n === stepNumber) el.classList.add('active');
            });
            document.querySelectorAll('.stepper-line').forEach((line, idx) => {
                const n = idx + 1;
                if (n < stepNumber) line.classList.add('done');
                else line.classList.remove('done');
            });
        }

        // Scrollspy — keeps the stepper synced to whichever section is
        // currently in view while scrolling, on top of (not instead of)
        // the explicit updateStep() calls elsewhere (package select, booking
        // confirmed). A thin band near the upper-middle of the viewport
        // decides which section counts as "current."
        document.addEventListener('DOMContentLoaded', function () {
            var spySections = [
                { el: document.getElementById('packages'), step: 1 },
                { el: document.getElementById('lp-booking'), step: 2 },
                { el: document.getElementById('booking'), step: 3 }
            ].filter(function (s) { return s.el; });

            if (spySections.length && 'IntersectionObserver' in window) {
                var spyObserver = new IntersectionObserver(function (entries) {
                    entries.forEach(function (entry) {
                        if (!entry.isIntersecting) return;
                        var match = spySections.find(function (s) { return s.el === entry.target; });
                        if (match) updateStep(match.step);
                    });
                }, { rootMargin: '-25% 0px -45% 0px', threshold: 0 });

                spySections.forEach(function (s) { spyObserver.observe(s.el); });
            }

            // Reusable premium ease-in/out scroll reveal. `stagger` (ms)
            // offsets each subsequent element for a gentle cascade;
            // omit/0 for a single element. Reversible: scrolling an
            // element out of view resets it so scrolling back plays the
            // reveal again. Releases the animation once settled, so
            // hover/other transitions on the same element work normally.
            function lpInitScrollReveal(elements, stagger) {
                if (!('IntersectionObserver' in window)) return;
                var els = Array.prototype.slice.call(elements);
                if (!els.length) return;
                els.forEach(function (el) { el.classList.add('lp-reveal', 'reveal-pending'); });

                var pendingExits = new WeakMap();
                var activeListeners = new WeakMap(); // el -> {event, handler} of the currently-armed animationend listener, so an interrupted one never gets left dangling

                function clearActiveListener(el) {
                    var active = activeListeners.get(el);
                    if (active) { el.removeEventListener('animationend', active); activeListeners.delete(el); }
                }

                var observer = new IntersectionObserver(function (entries) {
                    entries.forEach(function (entry) {
                        var el = entry.target;
                        var idx = els.indexOf(el);
                        if (entry.isIntersecting) {
                            // Cancel any pending exit — likely just a boundary
                            // flicker, not a genuine scroll-away.
                            var pending = pendingExits.get(el);
                            if (pending) { clearTimeout(pending); pendingExits.delete(el); }

                            // If it was still fully visible (exit only ever
                            // pending, never actually happened), leave it
                            // alone rather than needlessly replaying the
                            // entrance animation on something the visitor
                            // never actually saw disappear.
                            if (el.classList.contains('reveal-settled')) return;

                            clearActiveListener(el); // in case a previous entrance/exit was interrupted mid-flight
                            el.classList.remove('reveal-out', 'reveal-in');
                            void el.offsetWidth; // force a reflow so the browser treats this as a genuinely new animation start, not a no-op
                            el.style.animationDelay = (idx * (stagger || 0)) + 'ms';
                            el.classList.add('reveal-in');
                            function onIn() {
                                el.classList.remove('reveal-in');
                                el.classList.add('reveal-settled');
                                activeListeners.delete(el);
                            }
                            el.addEventListener('animationend', onIn);
                            activeListeners.set(el, onIn);
                        } else if (el.classList.contains('reveal-settled') || el.classList.contains('reveal-in')) {
                            // Debounce the exit only: wait briefly to confirm
                            // this is a real scroll-away, not a sub-pixel
                            // flicker right at the trigger boundary.
                            if (pendingExits.has(el)) return;
                            var t = setTimeout(function () {
                                pendingExits.delete(el);
                                clearActiveListener(el); // in case the entrance was still mid-flight when this exit fired
                                el.classList.remove('reveal-in', 'reveal-settled');
                                void el.offsetWidth;
                                el.style.animationDelay = '0ms';
                                el.classList.add('reveal-out');
                                function onOut() {
                                    el.classList.remove('reveal-out');
                                    activeListeners.delete(el);
                                }
                                el.addEventListener('animationend', onOut);
                                activeListeners.set(el, onOut);
                            }, 400);
                            pendingExits.set(el, t);
                        }
                    });
                }, { threshold: 0.1, rootMargin: '-25% 0px -25% 0px' });

                els.forEach(function (el) { observer.observe(el); });
            }
            window.lpInitScrollReveal = lpInitScrollReveal;

            lpInitScrollReveal(document.querySelectorAll('#lpb-form-card'), 0);
            lpInitScrollReveal(document.querySelectorAll('#payment-recap-package'), 0);

            // "Studio Policies" link in the payment acknowledgment — smooth
            // scroll matching the rest of the site, cleared of the sticky bar.
            var policyLink = document.getElementById('policy-link');
            if (policyLink) {
                policyLink.addEventListener('click', function (e) {
                    e.preventDefault();
                    var target = document.getElementById('studio-policies');
                    if (!target) return;
                    if (typeof lpSmoothScrollTo === 'function' && typeof lpStickyBarHeight === 'function') {
                        lpSmoothScrollTo(target, { duration: 700, offset: -(lpStickyBarHeight() + 20) });
                    } else {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                });
            }

            // Package card photo reveal — a portrait thumbnail eases in
            // beside the description once the card has sat in view for a
            // beat (not an instant scroll-trigger). Cancels the pending
            // timer if the card leaves view before it fires, and resets so
            // it can play again next time. Uses a thin band centered in the
            // viewport (not just "40% visible anywhere") so a card only
            // starts its dwell timer once it's genuinely centered on
            // screen — not merely peeking in at the top or bottom edge.
            //
            // Pulled into a named function (rather than running once
            // inline) so it can be called again after the real package
            // cards load in from the API — they don't exist yet at the
            // point this script first runs.
            function initPackageDwellReveal(cards) {
                if (!('IntersectionObserver' in window)) return;
                var photoTimers = new WeakMap();
                var pendingHides = new WeakMap();
                var dwellObserver = new IntersectionObserver(function (entries) {
                    entries.forEach(function (entry) {
                        var card = entry.target;
                        if (entry.isIntersecting) {
                            // Cancel any pending hide — likely just a boundary
                            // flicker, not a genuine scroll-away.
                            var pendingHide = pendingHides.get(card);
                            if (pendingHide) { clearTimeout(pendingHide); pendingHides.delete(card); }

                            if (card.classList.contains('photo-revealed') || photoTimers.has(card)) return;
                            var t = setTimeout(function () {
                                card.classList.add('photo-revealed');
                            }, 1200);
                            photoTimers.set(card, t);
                        } else {
                            var existing = photoTimers.get(card);
                            if (existing) { clearTimeout(existing); photoTimers.delete(card); }

                            if (!card.classList.contains('photo-revealed') || pendingHides.has(card)) return;
                            // Widened from 180ms — a slow, held scroll can leave
                            // a card hovering right at the trigger boundary for
                            // longer than that, causing it to rapidly hide and
                            // re-show. This gives more real buffer before it
                            // commits to hiding.
                            var hideTimer = setTimeout(function () {
                                pendingHides.delete(card);
                                card.classList.remove('photo-revealed');
                            }, 450);
                            pendingHides.set(card, hideTimer);
                        }
                    });
                }, { rootMargin: '-30% 0px -30% 0px', threshold: 0 });
                cards.forEach(function (card) { dwellObserver.observe(card); });
            }
            window.initPackageDwellReveal = initPackageDwellReveal;
        });

        // Shared smooth-scroll helper — used instead of the browser's native
        // `scrollIntoView({behavior:'smooth'})`, whose speed/easing can't be
        // controlled and often feels rushed on short distances. This one uses
        // a fixed duration with ease-in-out easing for a consistently gentle
        // motion, and is reused across the page wherever we scroll the user.
        function lpSmoothScrollTo(target, options) {
            options = options || {};
            var duration = options.duration || 700;
            var offset = options.offset || 0;

            var startY = window.pageYOffset;
            var targetY = target.getBoundingClientRect().top + startY + offset;
            var distance = targetY - startY;
            var startTime = null;

            function easeInOutCubic(t) {
                return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
            }

            function step(timestamp) {
                if (startTime === null) startTime = timestamp;
                var elapsed = timestamp - startTime;
                var progress = Math.min(elapsed / duration, 1);
                window.scrollTo(0, startY + distance * easeInOutCubic(progress));
                if (progress < 1) window.requestAnimationFrame(step);
            }

            window.requestAnimationFrame(step);
        }

        // The progress stepper is sticky/fixed to the top of the viewport,
        // so any programmatic scroll needs to stop short by its height —
        // otherwise section headings land underneath it and get clipped.
        // Computed live (not a fixed number) since the bar's height differs
        // between its normal and condensed "is-stuck" states.
        function lpStickyBarHeight() {
            var bar = document.getElementById('sticky-progress-wrap');
            var h = bar ? bar.getBoundingClientRect().height : 0;
            return h > 0 ? h : 90; // sensible fallback if it can't be measured
        }

        // Package Selection
        function selectPackage(btn) {
            // Remove selection from all cards
            document.querySelectorAll('.tier-card').forEach(card => card.classList.remove('selected'));
            document.querySelectorAll('.select-btn').forEach(b => b.innerText = "Select Session");

            // Add selection to clicked card
            const card = btn.closest('.tier-card');
            card.classList.add('selected');
            btn.innerText = "Selected";

            // Update Cart State
            cart.basePrice = parseFloat(card.getAttribute('data-price'));
            cart.baseName = card.getAttribute('data-name');

            // Enable Addons & update UI
            document.getElementById('addons-box').classList.add('active');
            document.getElementById('invoice-ui').classList.add('active');
            updateStep(2);

            // Seamless scroll to addons
            lpSmoothScrollTo(document.getElementById('addons'), {
                duration: 750,
                offset: -(lpStickyBarHeight() + 20)
            });

            calculateTotals();
        }

        // Add-on Checkbox Listeners
        document.querySelectorAll('.addon-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', () => {
                cart.addons = [];
                document.querySelectorAll('.addon-checkbox:checked').forEach(checkedBox => {
                    cart.addons.push({
                        name: checkedBox.getAttribute('data-name'),
                        price: parseFloat(checkedBox.value)
                    });
                });
                calculateTotals();
            });
        });

        // Calculate and Update UI
        function calculateTotals() {
            let addonTotal = cart.addons.reduce((sum, item) => sum + item.price, 0);
            
            cart.subtotal = cart.basePrice + addonTotal;
            cart.retainer = cart.subtotal * 0.70; 
            cart.balance = cart.subtotal * 0.30;

            // Update DOM Invoice
            document.getElementById('inv-package-name').innerText = cart.baseName;
            document.getElementById('inv-package-price').innerText = formatNaira(cart.basePrice);
            
            const addonsListUI = document.getElementById('inv-addons-list');
            addonsListUI.innerHTML = ""; 
            cart.addons.forEach(addon => {
                addonsListUI.innerHTML += `
                    <div class="invoice-row">
                        <span>+ ${addon.name}</span>
                        <span>${formatNaira(addon.price)}</span>
                    </div>`;
            });

            document.getElementById('inv-subtotal').innerText = formatNaira(cart.subtotal);
            document.getElementById('inv-balance').innerText = formatNaira(cart.balance);
            document.getElementById('inv-retainer').innerText = formatNaira(cart.retainer);

            // Recap right above the Paystack button — by the time a client
            // scrolls down to pay, they've usually scrolled past the invoice
            // above, so this keeps what they're paying for in view.
            document.getElementById('payment-recap-name').innerText = cart.baseName;
            document.getElementById('payment-recap-subtotal').innerText = formatNaira(cart.subtotal);
            document.getElementById('payment-recap-retainer-amount').innerText = formatNaira(cart.retainer);
            document.getElementById('payment-recap-package').style.display = 'block';

            // Enable & Update Payment Button
            const payBtn = document.getElementById('pay-btn');
            payBtn.removeAttribute('disabled');
            payBtn.innerText = `Pay Retainer (${formatNaira(cart.retainer)})`;
        }

        // Paystack Integration
        function payWithPaystack() {
            if (typeof PaystackPop === 'undefined') {
                alert("The payment module failed to load. Please check your connection or disable any ad blockers, then refresh the page. You can also reach out to us directly to complete your booking.");
                return;
            }

            // Enforce Book Appointment → Pay Retainer order: no retainer
            // charge without a real, saved booking behind it.
            if (!window.lpbBookingConfirmed) {
                alert('Please pick a date, time, and enter your details in the booking form above — and press "Book Appointment" — before paying the retainer.');
                var secureSessionEl = document.getElementById('secure-session');
                if (typeof lpSmoothScrollTo === 'function') {
                    lpSmoothScrollTo(secureSessionEl, {
                        duration: 700,
                        offset: -(lpStickyBarHeight() + 36)
                    });
                } else {
                    secureSessionEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
                return;
            }

            var policyCheckbox = document.getElementById('policy-ack');
            if (policyCheckbox && !policyCheckbox.checked) {
                alert('Please confirm you\'ve read and agree to the Studio Policies before paying.');
                policyCheckbox.focus();
                return;
            }

            const emailInput = document.getElementById('client-email').value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (!emailInput || !emailRegex.test(emailInput)) {
                alert("Please enter a valid email address before paying.");
                document.getElementById('client-email').focus();
                return;
            }

            if (cart.retainer === 0) {
                alert("Please select a session first.");
                return;
            }

            const amountInKobo = cart.retainer * 100;

            let handler = PaystackPop.setup({
                key: 'pk_live_05373c45337d6a937f51d9c3045c7839369d503d',
                email: emailInput,
                amount: amountInKobo,
                currency: 'NGN',
                callback: function(response) {
                    // Paystack's own checkout script strictly checks that
                    // this callback is a plain function (not async) — so
                    // the actual async work happens in a separate function
                    // called from here, rather than making this one async.
                    handlePaymentSuccess(response);
                },
                onClose: function() {
                    alert('Payment window closed.');
                }
            });
            handler.openIframe();
        }

        async function handlePaymentSuccess(response) {
            const payBtn = document.getElementById('pay-btn');
            payBtn.disabled = true;
            payBtn.textContent = 'Confirming your booking…';

            try {
                const confirmRes = await fetch(LPB_WORKER_URL + '/confirm-payment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        bookingId: window.lpbBookingData.id,
                        reference: response.reference,
                        packageName: cart.baseName,
                        packagePrice: cart.basePrice,
                        addons: cart.addons,
                        totalAmount: cart.subtotal,
                        retainerAmount: cart.retainer
                    })
                });
                const confirmResult = await confirmRes.json();
                if (!confirmRes.ok || !confirmResult.success) {
                    throw new Error('Payment succeeded, but saving the booking failed.');
                }

                // Payment succeeded AND the booking is now genuinely
                // saved — this is the moment the whole flow is real,
                // not just the payment step in isolation.
                updateStep(3);
                document.getElementById('client-email').style.display = 'none';
                document.getElementById('policy-ack').closest('label').style.display = 'none';
                payBtn.style.display = 'none';
                document.getElementById('payment-secure-note').style.display = 'none';
                document.getElementById('lpb-payment-reference').textContent = response.reference;
                document.getElementById('lpb-payment-success').style.display = 'block';

                // Redirect to WhatsApp with the booking details pre-filled —
                // opened in a new tab (some browsers block an automatic
                // popup here), so the button underneath is a reliable
                // fallback if that happens rather than the only way through.
                var waMessage = "Hi Libertypictures! I've just paid the retainer for my " + cart.baseName +
                    " (Reference: " + response.reference + "). Looking forward to my session!";
                var waLink = 'https://wa.me/2349075170240?text=' + encodeURIComponent(waMessage);
                document.getElementById('lpb-whatsapp-link').href = waLink;
                window.open(waLink, '_blank');
            } catch (err) {
                // Payment genuinely went through on Paystack's side even
                // if this save failed — so this must never claim the
                // booking didn't happen. It tells the truth and gives a
                // real way to resolve it, instead of losing a paid
                // booking silently.
                payBtn.disabled = false;
                payBtn.textContent = 'Retry Confirming Booking';
                alert('Your payment went through (Reference: ' + response.reference + '), but we hit an issue saving your booking. Please save this reference and reach out to us on WhatsApp so we can confirm it manually — nothing has been lost.');
            }
        }
    </script>

    <!-- ================================================================
         LP BOOKING COMPONENT — JAVASCRIPT
         Fully isolated in its own IIFE. Does not read from or write to
         any variable, function, or DOM node used by the cart/Paystack
         script above — the only shared resource is the page's CSS
         custom properties system (--accent, --bg-container, etc. are
         untouched; this component uses its own --lpb-* variables).
         ================================================================ -->
    <script>
    (function () {
        'use strict';

        /* ------------------------------------------------------------------
           CONFIG — the single line you need to edit.
           Set this to your deployed Cloudflare Worker's base URL (no
           trailing slash), e.g. 'https://liberty-booking.yoursubdomain.workers.dev'
        ------------------------------------------------------------------ */
        var LPB_WORKER_URL = 'https://liberty-booking-api.visualsliberty.workers.dev'; // real backend, own database — no Cal.com dependency
        var LPB_TIMEZONE   = 'Africa/Lagos';

        /* ------------------------------------------------------------------
           BOOKING SUBMISSION — single entry point for all booking logic.
           Calls the Cloudflare Worker's POST /book route, which talks to
           the Cal.com API. Everything above it (calendar, time slots,
           form, validation) stays exactly the same.
        ------------------------------------------------------------------ */
        async function submitBooking(bookingData) {
            var response = await fetch(LPB_WORKER_URL + '/book', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bookingData)
            });

            var result = {};
            try { result = await response.json(); } catch (e) { /* fall through */ }

            if (!response.ok || !result.success) {
                throw new Error((result && result.error) || 'Booking failed — please try again.');
            }

            return result.booking;
        }

        /* ------------------------------------------------------------------
           AVAILABILITY — calls the Worker's GET /availability route and
           converts each real slot into a { label, iso } pair: `label`
           is what the client sees ("10:00 AM"), `iso` is the exact UTC
           start time that gets sent back on submit.
        ------------------------------------------------------------------ */
        async function loadAvailableTimes(dateObj) {
            var dateParam = formatDateParam(dateObj);
            var url = LPB_WORKER_URL + '/availability?date=' + encodeURIComponent(dateParam) +
                '&timeZone=' + encodeURIComponent(LPB_TIMEZONE);

            var response = await fetch(url);
            var result = {};
            try { result = await response.json(); } catch (e) { /* fall through */ }

            if (!response.ok || !result.success) {
                throw new Error((result && result.error) || 'Failed to load availability.');
            }

            return (result.slots || []).map(function (slot) {
                return { iso: slot.start, label: formatSlotLabel(slot.start) };
            });
        }

        function formatDateParam(dateObj) {
            var y = dateObj.getFullYear();
            var m = String(dateObj.getMonth() + 1).padStart(2, '0');
            var d = String(dateObj.getDate()).padStart(2, '0');
            return y + '-' + m + '-' + d;
        }

        function formatSlotLabel(iso) {
            try {
                return new Intl.DateTimeFormat('en-US', {
                    hour: 'numeric',
                    minute: '2-digit',
                    hour12: true,
                    timeZone: LPB_TIMEZONE
                }).format(new Date(iso));
            } catch (e) {
                return iso;
            }
        }

        var MONTHS = ['January','February','March','April','May','June',
                      'July','August','September','October','November','December'];
        var DOWS   = ['Mo','Tu','We','Th','Fr','Sa','Su'];

        /* ------------------------------------------------------------------
           STATE
        ------------------------------------------------------------------ */
        var today     = new Date();
        var viewYear  = today.getFullYear();
        var viewMonth = today.getMonth();
        var selDate     = null;
        var selTime     = null;
        var selStartISO = null;

        /* ------------------------------------------------------------------
           DOM
        ------------------------------------------------------------------ */
        function $(id) { return document.getElementById(id); }
        var calGrid          = $('lpb-cal-grid');
        var monthLabel       = $('lpb-cal-month-label');
        var prevBtn          = $('lpb-prev-month');
        var nextBtn          = $('lpb-next-month');
        var timesGrid        = $('lpb-times-grid');
        var timesPlaceholder = $('lpb-times-placeholder');
        var nameInput        = $('lpb-name');
        var emailInput       = $('lpb-email');
        var submitBtn        = $('lpb-submit-btn');
        var submitHint       = $('lpb-submit-hint');
        var formCard         = $('lpb-form-card');
        var successCard      = $('lpb-success-card');
        var successMsg       = $('lpb-success-msg');

        /* ------------------------------------------------------------------
           CALENDAR
        ------------------------------------------------------------------ */
        function renderCalendar() {
            monthLabel.textContent = MONTHS[viewMonth] + ' ' + viewYear;
            prevBtn.disabled = (viewYear === today.getFullYear() && viewMonth === today.getMonth());
            calGrid.innerHTML = '';

            DOWS.forEach(function (d) {
                var el = document.createElement('div');
                el.className = 'lpb-cal-dow';
                el.textContent = d;
                calGrid.appendChild(el);
            });

            var firstDow      = new Date(viewYear, viewMonth, 1).getDay();
            var offset        = firstDow === 0 ? 6 : firstDow - 1;
            var daysInMonth   = new Date(viewYear, viewMonth + 1, 0).getDate();
            var todayMidnight = new Date(today.getFullYear(), today.getMonth(), today.getDate());

            for (var i = 0; i < offset; i++) {
                var empty = document.createElement('button');
                empty.className = 'lpb-cal-day lpb-day-empty';
                empty.disabled = true;
                empty.setAttribute('aria-hidden', 'true');
                calGrid.appendChild(empty);
            }

            for (var d = 1; d <= daysInMonth; d++) {
                (function (day) {
                    var btn       = document.createElement('button');
                    btn.type      = 'button';
                    btn.className = 'lpb-cal-day';
                    btn.textContent = day;

                    var thisDate   = new Date(viewYear, viewMonth, day);
                    var isPast     = thisDate < todayMidnight;
                    var isToday    = thisDate.getTime() === todayMidnight.getTime();
                    var isSelected = selDate &&
                        selDate.getFullYear() === viewYear &&
                        selDate.getMonth()    === viewMonth &&
                        selDate.getDate()     === day;

                    if (isPast)    { btn.classList.add('lpb-day-disabled'); btn.disabled = true; }
                    if (isToday)     btn.classList.add('lpb-day-today');
                    if (isSelected)  btn.classList.add('lpb-day-selected');

                    btn.setAttribute('aria-label',
                        MONTHS[viewMonth] + ' ' + day + ', ' + viewYear +
                        (isPast ? ' — unavailable' : ''));

                    if (!isPast) {
                        btn.addEventListener('click', function () {
                            selDate = new Date(viewYear, viewMonth, day);
                            selTime = null;
                            selStartISO = null;
                            renderCalendar();
                            renderTimes();
                            updateSubmit();
                        });
                    }
                    calGrid.appendChild(btn);
                })(d);
            }
        }

        /* ------------------------------------------------------------------
           TIME SLOTS
        ------------------------------------------------------------------ */
        function renderTimes() {
            if (!selDate) return;

            selTime = null;
            selStartISO = null;
            timesGrid.style.display = 'none';
            timesGrid.innerHTML = '';
            timesPlaceholder.style.display = 'block';
            timesPlaceholder.textContent = 'Loading available times…';
            updateSubmit();

            var requestedDate = selDate;

            loadAvailableTimes(requestedDate).then(function (slots) {
                // Ignore a stale response if the visitor already picked a
                // different date while this request was in flight.
                if (selDate !== requestedDate) return;

                if (!slots.length) {
                    timesPlaceholder.textContent = 'No available times for this date — please choose another day.';
                    timesPlaceholder.style.display = 'block';
                    timesGrid.style.display = 'none';
                    return;
                }

                timesPlaceholder.style.display = 'none';
                timesGrid.style.display = 'grid';
                renderSlots(slots);
            }).catch(function (err) {
                if (selDate !== requestedDate) return;
                console.error('[LibertyPictures Booking] failed to load availability:', err);
                timesPlaceholder.textContent = 'Could not load available times — please try again.';
                timesPlaceholder.style.display = 'block';
                timesGrid.style.display = 'none';
            });
        }

        function renderSlots(slots) {
            timesGrid.innerHTML = '';
            slots.forEach(function (slot) {
                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'lpb-time-btn';
                btn.textContent = slot.label;
                if (selStartISO === slot.iso) btn.classList.add('lpb-time-selected');
                btn.addEventListener('click', function () {
                    selTime = slot.label;
                    selStartISO = slot.iso;
                    timesGrid.querySelectorAll('.lpb-time-btn').forEach(function (b) {
                        b.classList.remove('lpb-time-selected');
                    });
                    btn.classList.add('lpb-time-selected');
                    updateSubmit();
                });
                timesGrid.appendChild(btn);
            });
            timesGrid.classList.add('lpb-animate-in');
        }

        /* ------------------------------------------------------------------
           SUBMIT STATE
        ------------------------------------------------------------------ */
        function updateSubmit() {
            var dateOk  = !!selDate;
            var timeOk  = !!selTime;
            var nameOk  = nameInput.value.trim().length > 1;
            var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim());
            submitBtn.disabled = !(dateOk && timeOk && nameOk && emailOk);
            if      (!dateOk)  submitHint.textContent = 'Select a date to continue';
            else if (!timeOk)  submitHint.textContent = 'Select an available time';
            else if (!nameOk)  submitHint.textContent = 'Enter your name to continue';
            else if (!emailOk) submitHint.textContent = 'Enter a valid email address';
            else               submitHint.textContent = '';
        }

        /* ------------------------------------------------------------------
           NAVIGATION
        ------------------------------------------------------------------ */
        prevBtn.addEventListener('click', function () {
            if (viewMonth === 0) { viewMonth = 11; viewYear--; } else viewMonth--;
            renderCalendar();
        });
        nextBtn.addEventListener('click', function () {
            if (viewMonth === 11) { viewMonth = 0; viewYear++; } else viewMonth++;
            renderCalendar();
        });
        [nameInput, emailInput].forEach(function (el) { el.addEventListener('input', updateSubmit); });

        /* ------------------------------------------------------------------
           SUBMISSION — routes through the single submitBooking(bookingData)
           entry point required for the future Cloudflare Worker / Cal.com
           integration. Everything else about the form stays the same.
        ------------------------------------------------------------------ */
        submitBtn.addEventListener('click', async function () {
            if (!selStartISO) {
                submitHint.textContent = 'Please select an available time before booking.';
                return;
            }

            var booking = {
                name:  nameInput.value.trim(),
                email: emailInput.value.trim(),
                start: selStartISO,
                timeZone: LPB_TIMEZONE
            };

            submitBtn.disabled = true;
            var originalLabel = submitBtn.textContent;
            submitBtn.textContent = 'Sending…';

            try {
                var savedBooking = await submitBooking(booking);

                // Unlocks the existing "Pay Retainer" step further down the
                // page — payment can't fire until a real booking has been
                // saved (holding the slot), matching the Book → Pay order.
                window.lpbBookingConfirmed = true;
                window.lpbBookingData = Object.assign({}, booking, { id: savedBooking.id });

                if (typeof updateStep === 'function') updateStep(3); // moving into Payment

                var clientEmailInput = document.getElementById('client-email');
                if (clientEmailInput && !clientEmailInput.value) {
                    clientEmailInput.value = booking.email;
                }

                showSuccess(booking);
            } catch (err) {
                console.error('[LibertyPictures Booking] submission failed:', err);
                submitHint.textContent = err.message || 'Something went wrong — please try again.';
                submitBtn.disabled = false;
                submitBtn.textContent = originalLabel;
            }
        });

        /* ------------------------------------------------------------------
           SUCCESS
        ------------------------------------------------------------------ */
        function showSuccess(booking) {
            var d = selDate;
            successMsg.innerHTML =
                'Your session request for <strong>' + MONTHS[d.getMonth()] + ' ' + d.getDate() +
                '</strong> at <strong>' + selTime + '</strong> has been received.<br>' +
                "We'll confirm within 24 hours — check <strong>" + booking.email + '</strong>.';

            // The calendar/form stays exactly as it is — nothing is hidden,
            // collapsed, or scrolled. This toast simply appears in place
            // right below the submit button; the client scrolls past it to
            // reach Payment whenever they're ready, on their own.
            successCard.classList.add('lpb-visible');
        }

        /* ------------------------------------------------------------------
           INIT
        ------------------------------------------------------------------ */
        renderCalendar();

    })();
    </script>
    <!-- ================================================================
         END LP BOOKING COMPONENT JAVASCRIPT
         ================================================================ -->


</body></html>
