        <!-- BOOKING / PAYMENT SECTION -->
        <div id="booking" class="booking-section">

            <!-- PAYSTACK INTERACTIVE SECURE RETAINER -->
            <h3 class="step-heading serif" id="secure-session">Secure Your Session</h3>
            <div class="payment-wrapper">
                <div class="payment-recap-box" id="payment-recap-package" style="display:none;">
