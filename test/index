                <p style="font-size: 11.5px; margin-top: 18px; color: var(--text-secondary);" id="payment-secure-note">Payments securely processed by Paystack.</p>
                <div id="lpb-payment-success" style="display:none; text-align:center; padding: 28px 4px 4px;">
                    <div style="width:52px; height:52px; border-radius:50%; background:var(--highlight-bg); display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    </div>
